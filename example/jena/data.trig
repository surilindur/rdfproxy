@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schema: <https://schema.org/> .

<http://localhost:8000/> {

    <http://localhost:8000/> rdf:type schema:WebSite ;
        schema:name "Example website" ;
        schema:description "Example description here." .

    <http://localhost:8000/#fragment> schema:name "Frontpage fragment" ;
        schema:description "Example fragment." .

    <http://localhost:8000/document> rdf:type schema:DigitalDocument ;
        schema:name "Document" ;
        schema:description "Example document." .

    <http://localhost:8000/markdown> rdf:type schema:Statement ;
        schema:name "Document" ;
        schema:text """# Example markdown

This should be a list:

* First
* Second
* Third

~~This is struck through.~~""" .

    <http://localhost:8000/redirected> owl:sameAs <http://localhost:8000/document> .

    <http://127.0.0.1:8000/test> rdf:type schema:DigitalDocument ;
        schema:name "Loopback document" ;
        schema:description "Example loopback document." .

}
